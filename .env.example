# TITAN APP T3 - Mẫu biến môi trường
# Copy file này thành .env và điền giá trị thực (không commit .env lên git)

# --- Bắt buộc ---
APP_SECRET_KEY=your-secret-key-min-32-chars

# --- Database (SQL Server) ---
DB_SERVER=your-server.database.windows.net
DB_NAME=CRM_STDD
DB_UID=your_db_user
DB_PWD=your_db_password

# --- Redis (Session + Cache) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- AI (Gemini - Chatbot / Training) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Tùy chọn ---
# UPLOAD_FOLDER_PATH có thể để mặc định (attachments trong thư mục app)
